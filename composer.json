{
  "name": "cekta/queue-postgres",
  "description": "Postgres implementation for cekta/queue",
  "type": "library",
  "license": "GPL-3.0-only",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "infection/extension-installer": true
    }
  },
  "require": {
    "php": ">=8.3",
    "ext-pdo": "*",
    "ramsey/uuid": "^4.9",
    "psr/clock": "^1.0",
    "psr/log": "^3.0",
    "psr/container": "^2.0",
    "cekta/queue": "dev-master"
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "@stable",
    "phpstan/phpstan": "@stable",
    "infection/infection": "@stable",
    "testo/testo": "@stable",
    "testo/bridge-infection": "@stable",
    "lcobucci/clock": "^3.5"
  },
  "scripts": {
    "test": [
      "@composer install",
      "@phpcs",
      "@phpstan",
      "@testo",
      "@infection"
    ],
    "phpcs": "./vendor/bin/phpcs",
    "phpstan": "./vendor/bin/phpstan analyse --memory-limit=-1",
    "testo": "./vendor/bin/testo",
    "infection": "./vendor/bin/infection --show-mutations"
  },
  "autoload": {
    "psr-4": {
      "Cekta\\Queue\\Postgres\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Cekta\\Queue\\Postgres\\Test\\": "tests/"
    }
  },
  "authors": [
    {
      "name": "Evgeniy Kuvshinov",
      "email": "smpl@itmywork.com"
    }
  ]
}
